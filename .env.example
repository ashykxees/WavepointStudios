# Discord bot credentials (required)
DISCORD_TOKEN=your-bot-token
CLIENT_ID=your-application-id

# Register commands instantly to a single guild (recommended).
# Leave blank to register global commands (can take up to 1 hour to appear).
GUILD_ID=your-server-id

# Verification: the role given to members who click the verify button.
# Required for the auto-posted panel. Can be overridden per-panel with the
# /verify_panel "role" option.
VERIFIED_ROLE_ID=

# Channel where the verification panel is auto-posted on startup.
# Defaults to the Wavepoint verification channel if unset.
VERIFY_PANEL_CHANNEL_ID=

# Comma-separated role IDs allowed to use the moderation commands
# (/kick, /ban, /timeout). Administrators are always allowed.
# Defaults to the staff roles baked into the code if unset.
MOD_ROLE_IDS=

# Optional. Default text shown on the verification panel.
VERIFY_TITLE=
VERIFY_DESCRIPTION=
VERIFY_BUTTON_LABEL=
VERIFY_BUTTON_EMOJI=

# Optional. Public image URL shown on the verification panel embed.
VERIFY_IMAGE_URL=
